; =============================================================================
; DWARFDUMP COMPARISON TESTS - MACOS
; =============================================================================

; --debug-str comparison

(rule
 (alias runtest)
 (target ocaml_debug_str.out)
 (deps %{bin:dwarfdump} ../fixtures/hello_world)
 (enabled_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (action
  (with-stdout-to
   %{target}
   (run
    %{bin:dwarfdump}
    --debug-str
    "../fixtures/hello_world.dSYM/Contents/Resources/DWARF/hello_world"))))

(rule
 (alias runtest)
 (target system_debug_str.out)
 (deps ../fixtures/hello_world)
 (enabled_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (action
  (with-stdout-to
   %{target}
   (system
    "dwarfdump --debug-str ../fixtures/hello_world.dSYM/Contents/Resources/DWARF/hello_world"))))

(rule
 (alias runtest)
 (deps ocaml_debug_str.out system_debug_str.out)
 (enabled_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (action
  (diff system_debug_str.out ocaml_debug_str.out)))

