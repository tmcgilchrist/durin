; Error handling test for directory input

(rule
 (alias runtest)
 (target directory_error_test.out)
 (deps %{bin:dwarfdump})
 (enabled_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (action
  (with-stderr-to
   %{target}
   (system "%{bin:dwarfdump} --debug-loclists . || true"))))

