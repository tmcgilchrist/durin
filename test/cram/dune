; macOS Cram Tests

(cram
 (enabled_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (deps %{bin:dwarfdump}))

(cram
 (deps %{bin:objdump} ../fixtures/hello_world)
 (enabled_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64"))))

